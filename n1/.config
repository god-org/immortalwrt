# ImmortalWrt Configuration
CONFIG_TARGET_armsr=y
CONFIG_TARGET_armsr_armv8=y
CONFIG_TARGET_armsr_armv8_DEVICE_generic=y
CONFIG_TARGET_ROOTFS_INITRAMFS=n
CONFIG_TARGET_ROOTFS_CPIOGZ=n
CONFIG_TARGET_ROOTFS_EXT4FS=n
CONFIG_TARGET_ROOTFS_SQUASHFS=n

# Base system
CONFIG_BUSYBOX_CUSTOM=y
# Archival Utilities
CONFIG_BUSYBOX_CONFIG_FEATURE_SEAMLESS_XZ=y
CONFIG_BUSYBOX_CONFIG_FEATURE_SEAMLESS_LZMA=y
CONFIG_BUSYBOX_CONFIG_FEATURE_SEAMLESS_BZ2=y
CONFIG_BUSYBOX_CONFIG_XZ=y
CONFIG_BUSYBOX_CONFIG_FEATURE_TAR_LONG_OPTIONS=y
CONFIG_BUSYBOX_CONFIG_FEATURE_TAR_AUTODETECT=y
CONFIG_BUSYBOX_CONFIG_FEATURE_TAR_UNAME_GNAME=y
CONFIG_BUSYBOX_CONFIG_FEATURE_TAR_NOPRESERVE_TIME=y
# Coreutils
CONFIG_BUSYBOX_CONFIG_STAT=y
CONFIG_BUSYBOX_CONFIG_FEATURE_STAT_FORMAT=y
CONFIG_BUSYBOX_CONFIG_FEATURE_STAT_FILESYSTEM=y
CONFIG_BUSYBOX_CONFIG_NOHUP=y
CONFIG_BUSYBOX_CONFIG_TAC=y
CONFIG_BUSYBOX_CONFIG_TIMEOUT=y
CONFIG_BUSYBOX_CONFIG_TRUNCATE=y
# Finding Utilities
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_ATIME=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_CTIME=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_AMIN=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_CMIN=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_EXECUTABLE=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_INUM=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_SAMEFILE=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_EXEC_PLUS=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_QUIT=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_DELETE=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_EMPTY=y
CONFIG_BUSYBOX_CONFIG_FEATURE_FIND_LINKS=y
CONFIG_BUSYBOX_CONFIG_FEATURE_XARGS_SUPPORT_REPL_STR=y
CONFIG_BUSYBOX_CONFIG_FEATURE_XARGS_SUPPORT_PARALLEL=y
CONFIG_BUSYBOX_CONFIG_FEATURE_XARGS_SUPPORT_ARGS_FILE=y
# Miscellaneous Utilities
CONFIG_BUSYBOX_CONFIG_FEATURE_LESS_FLAGS=y
CONFIG_BUSYBOX_CONFIG_FEATURE_LESS_TRUNCATE=y
CONFIG_BUSYBOX_CONFIG_FEATURE_LESS_REGEXP=y
CONFIG_BUSYBOX_CONFIG_FEATURE_LESS_WINCH=y
CONFIG_BUSYBOX_CONFIG_FEATURE_LESS_DASHCMD=y
CONFIG_BUSYBOX_CONFIG_FEATURE_LESS_LINENUMS=y
CONFIG_BUSYBOX_CONFIG_FEATURE_LESS_RAW=y
CONFIG_BUSYBOX_CONFIG_FEATURE_LESS_ENV=y
# Process Utilities
CONFIG_BUSYBOX_CONFIG_PKILL=y


# Kernel modules
# GPIO support
CONFIG_PACKAGE_kmod-gpio-pca953x=n
# I2C support
CONFIG_PACKAGE_kmod-i2c-mux-pca954x=n
# Network Devices
CONFIG_PACKAGE_kmod-amazon-ena=n
CONFIG_PACKAGE_kmod-atlantic=n
CONFIG_PACKAGE_kmod-bcmgenet=n
CONFIG_PACKAGE_kmod-dwmac-imx=n
CONFIG_PACKAGE_kmod-dwmac-rockchip=n
CONFIG_PACKAGE_kmod-dwmac-sun8i=n
CONFIG_PACKAGE_kmod-e1000e=n
CONFIG_PACKAGE_kmod-fsl-dpaa1-net=n
CONFIG_PACKAGE_kmod-fsl-dpaa2-net=n
CONFIG_PACKAGE_kmod-fsl-enetc-net=n
CONFIG_PACKAGE_kmod-fsl-fec=n
CONFIG_PACKAGE_kmod-mvneta=n
CONFIG_PACKAGE_kmod-mvpp2=n
CONFIG_PACKAGE_kmod-octeontx2-net=n
CONFIG_PACKAGE_kmod-phy-aquantia=n
CONFIG_PACKAGE_kmod-phy-broadcom=n
CONFIG_PACKAGE_kmod-phy-marvell=n
CONFIG_PACKAGE_kmod-phy-marvell-10g=n
CONFIG_PACKAGE_kmod-phy-realtek=n
CONFIG_PACKAGE_kmod-phy-smsc=n
CONFIG_PACKAGE_kmod-renesas-net-avb=n
CONFIG_PACKAGE_kmod-sfp=n
CONFIG_PACKAGE_kmod-vmxnet3=n
# Other modules
CONFIG_PACKAGE_kmod-wdt-sp805=n
# RTC Real-Time Clock Support
CONFIG_PACKAGE_kmod-rtc-rx8025=n
# USB Support
CONFIG_PACKAGE_kmod-usb2=y

# Languages
# Perl
CONFIG_PACKAGE_perl-http-date=n
CONFIG_PACKAGE_perlbase-file=y
CONFIG_PACKAGE_perlbase-getopt=n
CONFIG_PACKAGE_perlbase-time=y
CONFIG_PACKAGE_perlbase-unicode=n
CONFIG_PACKAGE_perlbase-utf8=y

# LuCI
# 3. Applications
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-app-amlogic=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-app-ksmbd=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-uhttpd=y

# Network
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_ppp=n
# File Transfer
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_rsync=y
CONFIG_RSYNC_zstd=y

# Utilities
CONFIG_PACKAGE_docker-compose=y
CONFIG_PACKAGE_gawk=y
CONFIG_PACKAGE_getopt=n
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_losetup=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_sshpass=y
CONFIG_PACKAGE_tar=n
CONFIG_PACKAGE_uuidgen=y
# Compression
CONFIG_PACKAGE_bsdtar=n
CONFIG_PACKAGE_pigz=n
CONFIG_PACKAGE_zstd=y
# Disc
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_parted=y
# Filesystem
CONFIG_PACKAGE_attr=n
CONFIG_PACKAGE_btrfs-progs=y
CONFIG_BTRFS_PROGS_ZSTD=y
CONFIG_PACKAGE_chattr=n
CONFIG_PACKAGE_dosfstools=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_f2fs-tools=n
CONFIG_PACKAGE_f2fsck=n
CONFIG_PACKAGE_lsattr=n
CONFIG_PACKAGE_mkf2fs=n
CONFIG_PACKAGE_xfs-fsck=n
CONFIG_PACKAGE_xfs-mkfs=n
# Shells
CONFIG_PACKAGE_bash=y
